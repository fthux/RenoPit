# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=renovate
DB_PASSWORD=renovate123
DB_NAME=renovate_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI 模型 (至少配置一个)
OPENAI_API_KEY=sk-xxxxxxxx
# GEMINI_API_KEY=xxxxxxxx

# 模型选择 (openai / gemini)
AI_MODEL_PROVIDER=openai

# 文件上传限制（字节，默认 20MB）
MAX_UPLOAD_SIZE=20971520

# 文本文件上传限制（字节，默认 5MB）
MAX_TEXT_FILE_SIZE=5242880

# 补充文本最大长度（字符，默认 2000）
MAX_INPUT_TEXT_LENGTH=2000

# 中文字体路径（Docker 环境中默认即可）
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# 联网搜索开关（默认启用，用于捕捉最新装修套路）
ENABLE_WEB_SEARCH=true