# ============================================================
# Database — PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=renovate
DB_PASSWORD=renovate123
DB_NAME=renovate_db

# 也可以直接用 DATABASE_URL 覆盖（测试时方便改成 SQLite）
# DATABASE_URL=sqlite+aiosqlite:///./test.db

# ============================================================
# Redis — Celery 消息代理与结果后端
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================
# LLM API Configuration (OpenAI SDK 兼容模式)
#
# 支持任意提供 OpenAI SDK 兼容接口的 LLM API:
#   · OpenAI:   LLM_API_KEY=sk-...  LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL_NAME=gpt-4o
#   · DeepSeek: LLM_API_KEY=sk-...  LLM_BASE_URL=https://api.deepseek.com/v1  LLM_MODEL_NAME=deepseek-chat
#   · Gemini (通过 Google 的 OpenAI 兼容端点):
#                LLM_API_KEY=AIzaSy...  LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  LLM_MODEL_NAME=gemini-2.5-flash
#   · Ollama:   LLM_API_KEY=ollama  LLM_BASE_URL=http://localhost:11434/v1  LLM_MODEL_NAME=qwen2.5:14b
# ============================================================
LLM_API_KEY=your_api_key
LLM_BASE_URL=llm_base_url
LLM_MODEL_NAME=llm_model_name

# ============================================================
# File upload limits (bytes)
# ============================================================
MAX_UPLOAD_SIZE=20971520
MAX_TEXT_FILE_SIZE=5242880
MAX_INPUT_TEXT_LENGTH=2000

# ============================================================
# Font path (Chinese font required for PDF report generation)
# ============================================================
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# ============================================================
# Feature flags
# ============================================================
ENABLE_WEB_SEARCH=true